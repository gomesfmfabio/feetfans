# Database Configuration (Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
SUPABASE_PROJECT_ID=your-project-id-here

# Supabase Public Keys (Safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (Server-side only - DO NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Age Verification (Onfido)
ONFIDO_API_TOKEN=your-onfido-api-token-here
ONFIDO_WEBHOOK_SECRET=your-onfido-webhook-secret-here
NEXT_PUBLIC_ONFIDO_SDK_TOKEN=your-onfido-sdk-token-here

# Payment Provider (Stripe - for Epic 4)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# Application Configuration
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Session & Authentication
JWT_SECRET=your-jwt-secret-here-minimum-32-characters-recommended
SESSION_EXPIRY_DAYS=30

# Storage Configuration (Supabase Storage)
NEXT_PUBLIC_STORAGE_BUCKET=content-uploads
MAX_UPLOAD_SIZE_MB=10

# Environment-Specific Settings
# For staging/production, copy this file to .env and update values
# Development: Use local Supabase instance or development project
# Staging: Use dedicated staging Supabase project
# Production: Use production Supabase project with strict RLS policies
